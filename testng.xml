<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite parallel="tests" name="Test Suite">
    <listeners>
        <listener class-name="Listener">
        </listener>
    </listeners>
    <test thread-count="5" name="submitOrder">
        <classes>
            <class name="End_to_EndTest"/>
        </classes>
    </test>
    <test thread-count="5" name="Regression Tests">
        <classes>
            <class name="End_End_Error_Test"/>
        </classes>
    </test>
</suite>